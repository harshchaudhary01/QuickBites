# Backend Configuration (.env)
# Copy this file to .env and fill in your own values

# Server
PORT=5000

# Database
MONGODB_URL=mongodb+srv://your_user:your_password@cluster.mongodb.net/QuickBites

# Security
JWT_SECRET=your_long_secure_secret_key_here

# Frontend URL (for CORS)
# For production, use your Vercel frontend URL
FRONTEND_URL=http://localhost:5173

# Email Configuration (Nodemailer)
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password_here

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay (Payment Gateway - Use TEST keys for development)
RAZORPAY_TEST_API_KEY=your_test_api_key
RAZORPAY_TEST_KEY_SECRET=your_test_key_secret
